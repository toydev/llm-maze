{
  "name": "maze-exploration-experiment",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "start": "vite-node src/main.ts",
    "test": "vitest",
    "test:diff": "diff -r test/snapshot/actual test/snapshot/expected || echo 'スナップショットに差分があります。内容確認後に test:update を実行してください。'",
    "test:update": "VITEST_UPDATE_SNAPSHOTS=true vitest",
    "evaluate": "vite-node src/evaluate.ts"
  },
  "dependencies": {
    "@langchain/google-genai": "^1.0.3",
    "@langchain/langgraph": "^1.0.4",
    "@langchain/ollama": "^1.0.3",
    "dotenv": "^17.2.3",
    "loglevel": "^1.9.2",
    "yaml": "^2.8.2",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "typescript": "^5",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
